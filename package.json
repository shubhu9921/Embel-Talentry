{
  "name": "hiring-system-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-db": "json-server --watch db.json --port 8083 --quiet",
    "dev:sync": "concurrently -n \"APP,SYNC\" -c \"cyan,magenta\" \"npm run dev\" \"npm run sync-db\"",
